# AI 充电桩客服模块 — 环境变量模板
# 复制为 backend/.env.dify-charge 后填入真实值

# ---- Dify API ----
DIFY_API_BASE=https://ai.trendpower.cc/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx
DIFY_WORKFLOW_ID=

# Workflow 输入变量名(与 v2 graph 对齐)
DIFY_INPUT_TEXT=input_text
DIFY_INPUT_LANGUAGE=input_language
DIFY_INPUT_SESSION_ID=input_session_id
DIFY_INPUT_TURN=input_turn
DIFY_INPUT_HINT_ENDPOINT=input_hint_endpoint
DIFY_INPUT_HINT_REGION=input_hint_region
DIFY_INPUT_ANSWERS=input_answers
DIFY_END_USER=h5-charge-consult

# ---- App ----
APP_NAME=AI Charge Consult
APP_VERSION=0.1.0
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:8082
PORT=8014