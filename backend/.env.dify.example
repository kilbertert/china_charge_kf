# H5 Dify Chatflow 后端（复制为 backend/.env.dify 后填写真实 token）
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:8082
PORT=8012

DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY_A=app-xxxxxxxxxxxxxxxxxxxx
DIFY_API_KEY_B=app-yyyyyyyyyyyyyyyyyyyy
DIFY_END_USER=h5-frontend-user

# 120 Bug API：用于把 H5 首轮截图按 Dify B conversation_id 跨轮缓存，
# 后续确认写表时由 /internal/bugtrack/add 写入飞书附件。
BUGTRACK_API_BASE=http://120.55.45.59:8501
BUGTRACK_IMAGE_CACHE_TIMEOUT=20
