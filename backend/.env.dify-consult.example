# AI 健康咨询模块 — 环境变量模板
# 复制为 backend/.env.dify-consult 后填入真实值

# ---- Dify API ----
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx
DIFY_WORKFLOW_ID=AI_health_consultant_v2

# Workflow 输入变量名(一般不需要改,与 v2.yml 对齐)
DIFY_INPUT_TEXT=input_text
DIFY_INPUT_IMAGE=input_img_id
DIFY_INPUT_ANSWERS=input_answers
DIFY_INPUT_LANGUAGE=input_language
DIFY_INPUT_SESSION_ID=input_session_id
DIFY_OUTPUT_TEXT=output
DIFY_END_USER=h5-health-consult

# 知识库 dataset id(部署时填)
DIFY_DATASET_PRODUCT=
DIFY_DATASET_QUESTIONNAIRE=
DIFY_DATASET_SOLUTION=

# ---- App ----
APP_NAME=health-consult
APP_VERSION=0.1.0
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:8082
PORT=8013
